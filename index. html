            <h3>Polki & Kundan Jewellery</h3>
        </div>
        <div class="card">
            <img src="https://images.unsplash.com/photo-1617038220319-5ae8e2c1c3f5?w=500" alt="Minimal Jewellery">
            <h3>Minimal & Regular Wear Jewellery</h3>
        </div>
        <div class="card">

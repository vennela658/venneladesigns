<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vennela Design Studio - Shop | Vijayawada | Narasaraopet</title>
  <style>
    body {margin:0; font-family:'Segoe UI', sans-serif; background:#0a0a0a; color:#fff;}
    header {background:#000; padding:15px 20px; text-align:center; border-bottom:3px solid #D4AF37; position:sticky; top:0;}
    header h1 {color:#D4AF37; margin:0; font-size:22px; letter-spacing:2px;}
    .hero {padding:60px 20px; text-align:center; background:linear-gradient(#111, #000);}
    .hero h2 {font-size:32px; color:#D4AF37; margin-bottom:10px;}
    .hero p {color:#aaa;}
    .section-title {text-align:center; font-size:26px; color:#D4AF37; padding:30px 20px 10px;}
    .products {display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:20px; padding:20px; max-width:1200px; margin:auto;}
    .card {background:#1a1a1a; border:1px solid #333; border-radius:12px; padding:15px; text-align:center; transition:0.3s;}
    .card:hover {border-color:#D4AF37; transform:translateY(-5px);}
    .card img {width:100%; height:200px; object-fit:cover; border-radius:8px; background:#222;}
    .card h3 {color:#D4AF37; margin:10px 0 5px;}
    .card p {color:#aaa; font-size:13px; min-height:35px;}
    .price {color:#D4AF37; font-weight:bold; font-size:18px; margin:10px 0;}
    .btn {background:#D4AF37; color:#000; padding:10px; border:none; border-radius:5px; font-weight:bold; cursor:pointer; width:48%; margin-top:5px;}
    .like-btn {background:#333; color:#D4AF37; border:1px solid #D4AF37;}
    .tag {background:#D4AF37; color:#000; padding:3px 8px; border-radius:20px; font-size:11px; font-weight:bold; float:left;}
    /* Popup Form */
    .popup {display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:1000; justify-content:center; align-items:center;}
    .popup-content {background:#1a1a1a; padding:30px; border-radius:10px; border:2px solid #D4AF37; width:90%; max-width:400px;}
    .popup-content h2 {color:#D4AF37; margin-top:0;}
    .popup-content input, .popup-content textarea {width:100%; padding:10px; margin:8px 0; background:#000; border:1px solid #333; color:#fff; border-radius:5px; box-sizing:border-box;}
    .close {float:right; font-size:24px; cursor:pointer; color:#D4AF37;}
    footer {background:#000; text-align:center; padding:30px 20px; border-top:3px solid #D4AF37; color:#aaa; margin-top:40px;}
  </style>
</head>
<body>
  <header><h1>VENNELA DESIGN STUDIO</h1></header>

  <section class="hero">
    <h2>TRADITIONAL & MODERN JEWELLERY</h2>
    <p>Vijayawada | Narasaraopet | COD Available</p>
  </section>

  <h2 class="section-title">MODERN COLLECTION</h2>
  <section class="products">
    <div class="card">
      <span class="tag">MODERN</span>
      <img src="https://via.placeholder.com/300x200/D4AF37/000?text=Necklace" alt="Necklace">
      <h3>Minimalist Gold Necklace</h3>
      <p>Sleek design for daily wear & office</p>
      <div class="price">₹3,499</div>
      <button class="btn like-btn" onclick="likeProduct('Minimalist Gold Necklace')">❤️ Like</button>
      <button class="btn" onclick="openForm('Minimalist Gold Necklace', 3499)">Buy Now</button>
    </div>

    <div class="card">
      <span class="tag">MODERN</span>
      <img src="https://via.placeholder.com/300x200/D4AF37/000?text=Earrings" alt="Earrings">
      <h3>Geometric Stud Earrings</h3>
      <p>Bold shapes, lightweight & classy</p>
      <div class="price">₹1,299</div>
      <button class="btn like-btn" onclick="likeProduct('Geometric Stud Earrings')">❤️ Like</button>
      <button class="btn" onclick="openForm('Geometric Stud Earrings', 1299)">Buy Now</button>
    </div>
  </section>

  <h2 class="section-title">TRADITIONAL COLLECTION</h2>
  <section class="products">
    <div class="card">
      <span class="tag">TRADITIONAL</span>
      <img src="https://via.placeholder.com/300x200/D4AF37/000?text=Temple" alt="Temple">
      <h3>Temple Necklace Set</h3>
      <p>22k Gold plated with antique finish</p>
      <div class="price">₹9,999</div>
      <button class="btn like-btn" onclick="likeProduct('Temple Necklace Set')">❤️ Like</button>
      <button class="btn" onclick="openForm('Temple Necklace Set', 9999)">Buy Now</button>
    </div>

    <div class="card">
      <span class="tag">TRADITIONAL</span>
      <img src="https://via.placeholder.com/300x200/D4AF37/000?text=Chandbali" alt="Chandbali">
      <h3>Chandbali Earrings</h3>
      <p>Bridal wear with kundan & pearls</p>
      <div class="price">₹4,499</div>
      <button class="btn like-btn" onclick="likeProduct('Chandbali Earrings')">❤️ Like</button>
      <button class="btn" onclick="openForm('Chandbali Earrings', 4499)">Buy Now</button>
    </div>
  </section>

  <!-- ORDER POPUP -->
  <div class="popup" id="orderPopup">
    <div class="popup-content">
      <span class="close" onclick="closeForm()">×</span>
      <h2>Place Order</h2>
      <p id="product-info" style="color:#D4AF37;"></p>
      <form action="https://formsubmit.co/venneladesignstudio@gmail.com" method="POST">
        <input type="hidden" name="_subject" value="New Order - Vennela Design Studio">
        <input type="hidden" name="Product" id="product-name">
        <input type="text" name="Name" placeholder="Your Name" required>
        <input type="tel" name="Phone" placeholder="Phone Number" required>
        <textarea name="Address" placeholder="Full Address with Pincode" rows="3" required></textarea>
        <button type="submit" class="btn" style="width:100%;">Submit Order</button>
      </form>
    </div>
  </div>

  <footer>
    <p>© 2026 Vennela Design Studio | Vijayawada | Narasaraopet</p>
  </footer>

<script>
  function likeProduct(productName){
    alert(productName + " liked! Thank you ❤️");
  }

  function openForm(name, price){
    document.getElementById('orderPopup').style.display = 'flex';
    document.getElementById('product-info').innerText = name + " - ₹" + price;
    document.getElementById('product-name').value = name + " - ₹" + price;
  }
  function closeForm(){
    document.getElementById('orderPopup').style.display = 'none';
  }
</script>
</body>
</html>

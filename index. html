<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vennela Design Studio - Crown Yourself Daily</title>
    <meta name="description" content="Vennela Design Studio - Modern Jewellery, Temple, Diamond, Antique, Bridal & Custom Design in Vijayawada">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }
        body { 
            font-family: 'Georgia', serif; 
            background: #0a0a0a; 
            color: #fff; 
            line-height: 1.6;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
        /* Header */
        header { 
            background: #000; 
            padding: 20px 0; 
            position: sticky; 
            top: 0; 
            z-index: 100;
            border-bottom: 1px solid #d4af37;
        }
        nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; }
        .logo { font-size: 22px; font-weight: bold; color: #d4af37; letter-spacing: 2px; }
        .menu a { color: #fff; text-decoration: none; margin: 0 12px; font-size: 13px; letter-spacing: 1px; }
        .menu a:hover { color: #d4af37; transition: 0.3s; }
        
        /* Hero */
        .hero { 
            text-align: center; 
            padding: 120px 20px; 
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=1400') center/cover fixed;
        }
        .hero h1 { font-size: 52px; color: #d4af37; margin-bottom: 15px; letter-spacing: 3px; }
        .hero p { font-size: 22px; margin-bottom: 35px; font-style: italic; }
        .btn { 
            background: #d4af37; 
            color: #000; 
            padding: 14px 35px; 
            text-decoration: none; 
            border-radius: 3px; 
            font-weight: bold;
            display: inline-block;
            letter-spacing: 1px;
        }
        .btn:hover { background: #c19d2f; }
        
        /* Sections */
        section { padding: 90px 0; }
        h2 { text-align: center; font-size: 38px; color: #d4af37; margin-bottom: 60px; letter-spacing: 2px; }
        
        /* Grid */
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); 
            gap: 35px; 
        }
        .card { 
            background: #1a1a1a; 
            border-radius: 8px; 
            overflow: hidden; 
            text-align: center;
            border: 1px solid #333;
            transition: transform 0.3s, border 0.3s;
        }
        .card:hover { transform: translateY(-5px); border-color: #d4af37; }
        .card img { width: 100%; height: 280px; object-fit: cover; }
        .card h3 { padding: 20px; font-size: 17px; color: #d4af37; line-height: 1.5; }
        .card p { padding: 0 20px 20px; font-size: 14px; color: #aaa; }
        
        /* About */
        .about { background: #111; text-align: center; }
        .about p { max-width: 850px; margin: 0 auto; font-size: 18px; color: #ccc; }
        
        /* Contact */
        .contact { text-align: center; background: #0a0a0a; }
        .contact-info { font-size: 18px; margin: 20px 0; }
        .contact a { color: #d4af37; text-decoration: none; }
        .contact a:hover { text-decoration: underline; }
        
        footer { background: #000; text-align: center; padding: 30px; color: #666; border-top: 1px solid #222; }
        
        @media(max-width: 768px) {
            .hero h1 { font-size: 32px; }
            .hero p { font-size: 18px; }
            .menu { display: none; }
            h2 { font-size: 28px; }
        }
    </style>
</head>
<body>


.contact{margin-top:40px;}
.contact p{color:#D4AF37;font-size:14px;}

/* Mobile Responsive */
@media(max-width:768px){
.hero{flex-direction:column;padding:30px 20px;}
header{padding:20px;}
.grid{grid-template-columns:repeat(2,1fr);}
}
